# LLM API（OpenAI-compatible）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=60
# OpenAI-compatible extension parameters; DeepSeek V4 thinking is disabled for Day 3.
LLM_EXTRA_BODY={"thinking":{"type":"disabled"}}

# Day 6 local document Embedding (no API key; CPU only)
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_MODEL_REVISION=4bf3c54884c552e68da7eb27f3e9bdc5a32e32d4
EMBEDDING_DIMENSION=512
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true
EMBEDDING_CACHE_DIR=data/models
EMBEDDING_DOWNLOAD_MAX_RETRIES=3
EMBEDDING_RETRY_BASE_DELAY_SECONDS=1.0

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ragagent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents
QDRANT_TIMEOUT_SECONDS=10.0
QDRANT_UPSERT_BATCH_SIZE=32

# 应用
APP_NAME=Enterprise Knowledge Base RAG Agent
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE=20971520
MAX_PDF_PAGES=500
READ_CHUNK_SIZE=1048576

# Day 5 text chunking (o200k_base is a reproducible counting baseline)
CHUNK_SIZE=500
CHUNK_OVERLAP=100
CHUNK_ENCODING_NAME=o200k_base
